{
  "tasks": {
    "check": "deno fmt --check . && deno lint . && deno check **/*.ts && deno check **/*.tsx",
    "dev": "deno run -A --watch=static/,routes/ dev.ts",
    "build": "deno run -A dev.ts build",
    "start": "deno run -A main.ts",
    "update": "deno run -A -r jsr:@fresh/update ."
  },
  "lint": {
    "rules": {
      "tags": [
        "fresh",
        "recommended"
      ],
      "include": [
        "camelcase",
        "no-await-in-loop",
        "no-console",
        "no-eval",
        "no-external-import",
        "no-implicit-declare-namespace-export",
        "no-inferrable-types",
        "no-self-compare",
        "no-sparse-arrays",
        "no-throw-literal",
        "no-useless-rename",
        "prefer-ascii",
        "triple-slash-reference",
        "verbatim-module-syntax"
      ]
    }
  },
  "fmt": {
    "lineWidth": 100,
    "semiColons": false
  },
  "exclude": [
    "**/_fresh/*",
    "node_modules/",
    ".devcontainer"
  ],
  "imports": {
    "@fontsource-variable/roboto": "npm:@fontsource-variable/roboto@5.2.5",
    "@fontsource-variable/roboto-mono": "npm:@fontsource-variable/roboto-mono@5.2.6",
    "@fontsource-variable/roboto-slab": "npm:@fontsource-variable/roboto-slab@5.2.5",
    "@preact/signals": "npm:@preact/signals@2.2.0",
    "@std/http": "jsr:@std/http@1.0.17",
    "@std/path": "jsr:@std/path@1.1.0",
    "@tailwindcss/postcss": "npm:@tailwindcss/postcss@4.1.8",
    "fresh": "jsr:@fresh/core@2.0.0-alpha.34",
    "i18next": "npm:i18next@25.2.1",
    "postcss": "npm:postcss@8.5.4",
    "preact": "npm:preact@10.26.8",
    "tailwindcss": "npm:tailwindcss@4.1.8"
  },
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.asynciterable",
      "dom.iterable",
      "deno.ns"
    ],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head"
    ]
  },
  "nodeModulesDir": "auto"
}
