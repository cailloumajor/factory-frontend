{
  "tasks": {
    "check": "deno fmt --check . && deno lint . && deno check **/*.ts && deno check **/*.tsx",
    "dev": "vite",
    "test-config": "deno run -RW tests/generate-config.ts",
    "test": "deno task test-config && deno test -E -c deno-tests.json",
    "build": "vite build",
    "start": "deno serve -A _fresh/server.js",
    "update": "deno run -A -r jsr:@fresh/update ."
  },
  "unstable": [
    "raw-imports"
  ],
  "lint": {
    "rules": {
      "tags": [
        "fresh",
        "recommended"
      ],
      "include": [
        "camelcase",
        "no-await-in-loop",
        "no-console",
        "no-eval",
        "no-external-import",
        "no-implicit-declare-namespace-export",
        "no-inferrable-types",
        "no-self-compare",
        "no-sparse-arrays",
        "no-throw-literal",
        "no-useless-rename",
        "triple-slash-reference",
        "verbatim-module-syntax"
      ]
    }
  },
  "fmt": {
    "lineWidth": 100,
    "semiColons": false,
    "exclude": [
      "static/logo.svg"
    ]
  },
  "exclude": [
    "**/_fresh/*",
    "node_modules/",
    ".devcontainer"
  ],
  "imports": {
    "@cailloumajor/frontend-utils-wasm": "jsr:@cailloumajor/frontend-utils-wasm@5.1.1",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@1.0.2",
    "@fontsource-variable/roboto": "npm:@fontsource-variable/roboto@5.2.6",
    "@fontsource-variable/roboto-mono": "npm:@fontsource-variable/roboto-mono@5.2.6",
    "@happy-dom/global-registrator": "npm:@happy-dom/global-registrator@^18.0.1",
    "@mdi/js": "npm:@mdi/js@7.4.47",
    "@preact/signals": "npm:@preact/signals@2.3.1",
    "@std/assert": "jsr:@std/assert@1.0.14",
    "@std/async": "jsr:@std/async@1.0.14",
    "@std/encoding": "jsr:@std/encoding@1.0.10",
    "@std/http": "jsr:@std/http@1.0.20",
    "@std/path": "jsr:@std/path@1.1.2",
    "@std/testing": "jsr:@std/testing@1.0.15",
    "@std/text": "jsr:@std/text@1.0.16",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@4.1.13",
    "@testing-library/preact": "npm:@testing-library/preact@3.2.4",
    "@types/morgan": "npm:@types/morgan@1.9.10",
    "clsx": "npm:clsx@2.1.1",
    "daisyui": "npm:daisyui@5.1.10",
    "fresh": "jsr:@fresh/core@2.0.2",
    "i18next": "npm:i18next@25.5.2",
    "morgan": "npm:morgan@1.10.1",
    "preact": "npm:preact@10.27.1",
    "tailwindcss": "npm:tailwindcss@4.1.13",
    "vite": "npm:vite@7.1.5",
    "zod": "npm:zod@4.1.8"
  },
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.asynciterable",
      "dom.iterable",
      "deno.ns"
    ],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ],
    "types": [
      "vite/client"
    ]
  },
  "nodeModulesDir": "auto"
}
